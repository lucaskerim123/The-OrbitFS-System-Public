{
    "id":  "mcp",
    "name":  "OrbitFS MCP",
    "version":  "0.1.0",
    "detachable":  true,
    "frontend":  "frontend",
    "licenseComponent":  "orbitfs_mcp",
    "runtimeRoot":  "C:/ProgramData/OrbitFS/MCP",
    "sourceRoot":  "C:/New Setup/dev/OrbitFS-MCP-1",
    "serviceName":  "OrbitFSMcpServer",
    "healthUrl":  "http://127.0.0.1:3939/health",
    "preflightCommand":  "npm run panel-preflight",
    "installCommand":  "powershell -ExecutionPolicy Bypass -File scripts/plugin-lifecycle.ps1 install",
    "attachCommand":  "powershell -ExecutionPolicy Bypass -File scripts/plugin-lifecycle.ps1 attach",
    "detachCommand":  "powershell -ExecutionPolicy Bypass -File scripts/plugin-lifecycle.ps1 detach",
    "uninstallCommand":  "powershell -ExecutionPolicy Bypass -File scripts/plugin-lifecycle.ps1 uninstall",
    "menuVisibleWhen":  [
                            "installed",
                            "licensed",
                            "attached"
                        ],
    "onlineRequiredForMenu":  false,
    "publicFiles":  [
                        "frontend/lib/mcp-plugin-status.svelte",
                        "frontend/routes/mcp/+page.svelte"
                    ]
}
